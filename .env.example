# ── WooCommerce REST API ───────────────────────────────────────────────────
# Your WordPress/WooCommerce site URL (no trailing slash)
# For WordPress.com: https://pawwellco.wordpress.com
# For custom domain: https://yourdomain.com
WC_URL=https://pawwellco.wordpress.com

# WooCommerce REST API Keys
# Generate at: WP Admin → WooCommerce → Settings → Advanced → REST API
# Create a key with "Read" permission for product fetching
WC_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Public variables (visible in the browser) ─────────────────────────────
# Used for the checkout redirect URL in CartView.tsx
NEXT_PUBLIC_WC_URL=https://pawwellco.wordpress.com
