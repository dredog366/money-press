#  https://dashboard.stripe.com/apikeysStripe 
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Webhook  https://dashboard.stripe.com/webhooksSecret 
# Add endpoint: https://facetea.org/api/fulfill (event: checkout.session.completed)
# Then paste the signing secret here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# CJ  https://www.cjdropshipping.com/myCJ.html#/apikeyDropshipping 
# Used by: scripts/fill-cj-mapping.js, api/fulfill.js, scripts/restock-agent.js
CJ_API_KEY=your_cj_api_key_here
CJ_ACCESS_TOKEN=your_cj_access_token_here
